# iM One NL2SQL Agent environment template.
# Copy to .env or export the values in your shell before running web/preflight commands.

# POC LLM gateway. Use either an approved OpenAI-compatible remote endpoint with
# OPENAI_API_KEY, or a localhost runtime explicitly allowed for no-auth demos.
OPENAI_API_KEY=
IM_ONE_LLM_MODEL=gpt-5.6-luna
IM_ONE_LLM_BASE_URL=https://api.openai.com/v1
IM_ONE_LLM_TIMEOUT=10

# Local no-auth LLM demo option.
# IM_ONE_LLM_BASE_URL=http://127.0.0.1:11434/v1
# IM_ONE_LLM_MODEL=local-nl2sql
# IM_ONE_LLM_ALLOW_LOCAL_NO_AUTH=1

# Optional API token for protected web endpoints.
IM_ONE_API_TOKEN=

# Pilot trusted-header mode for an internal SSO/API gateway.
# IM_ONE_AUTH_MODE=trusted_headers
# IM_ONE_TRUSTED_PROXY_TOKEN=

# Read-only database mode for read-replica style execution.
# IM_ONE_DB_READONLY=1

# Semantic backlog / feedback event store.
IM_ONE_FEEDBACK_PATH=logs/feedback.jsonl

# Optional embedding gateway for schema retrieval.
# IM_ONE_EMBEDDING_MODEL=text-embedding-3-small
# IM_ONE_EMBEDDING_BASE_URL=https://api.openai.com/v1
# IM_ONE_EMBEDDING_TIMEOUT=20

# Local no-auth embedding demo option.
# IM_ONE_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
# IM_ONE_EMBEDDING_MODEL=local-embedding
# IM_ONE_EMBEDDING_ALLOW_LOCAL_NO_AUTH=1
